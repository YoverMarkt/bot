# ============================================================
# BOTPANEL SAAS — Plantilla de variables de entorno
# Copia este archivo a .env y llena los valores.
# NUNCA pongas valores reales aquí ni subas tu .env a git.
# ============================================================

# ── SUPABASE ──────────────────────────────────────────────
# Supabase → Settings → API
SUPABASE_URL=                    # https://xxxx.supabase.co
SUPABASE_KEY=                    # anon / publishable (pública)
SUPABASE_SERVICE_KEY=            # secret / service_role (SOLO servidor, bypassa RLS)

# ── JWT ───────────────────────────────────────────────────
# Frase aleatoria larga (genera una con: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))")
JWT_SECRET=

# ── SUPERADMIN (login de /admin — vive solo en el entorno) ─
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── IA (opcional aquí: lo normal es guardarlas en el panel) ─
# El proveedor activo y las keys se administran en Admin → Configuración.
# Estas son solo respaldo del .env.
GROQ_API_KEY=                    # console.groq.com/keys (gratis)
GEMINI_API_KEY=                  # aistudio.google.com/apikey (gratis)
OPENAI_API_KEY=                  # platform.openai.com
ANTHROPIC_API_KEY=               # console.anthropic.com

# ── TELEGRAM (bot compartido para pruebas) ────────────────
TELEGRAM_BOT_TOKEN=              # @BotFather → /newbot

# ── RETELL (voz telefónica, opcional) ─────────────────────
RETELL_API_KEY=

# ── SEGURIDAD DE WEBHOOKS (opcional, recomendado en prod) ──
# Si defines este secreto, los webhooks exigen ?secret=<valor> en la URL.
# Configura la URL en YCloud/Kapso como: https://tu-dominio/webhook/ycloud?secret=<valor>
WEBHOOK_SECRET=
# Meta: si lo defines, se verifica la firma HMAC del webhook de Meta.
META_APP_SECRET=

# ── SERVIDOR / PRODUCCIÓN ─────────────────────────────────
PORT=3000
# En producción: tu dominio fijo (sin / al final). Esto DESACTIVA el túnel local.
# Ej: BASE_URL=https://tubot.up.railway.app
BASE_URL=

# ── NOTA ──────────────────────────────────────────────────
# Las credenciales de WhatsApp por cliente (YCloud/Meta/Kapso) NO van aquí:
# se guardan por negocio en la base de datos desde el panel admin.
