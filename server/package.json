{
  "name": "@botpanel/server",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prestart": "npm run build",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --ext ts --ignore dist --exec \"npm run build && node dist/index.js\"",
    "pretest": "npm run build",
    "test": "vitest run tests/",
    "lint": "eslint eslint.config.js tests && oxlint src",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "check": "npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@supabase/supabase-js": "^2.43.0",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "openai": "^6.45.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^26.1.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "nodemon": "^3.1.0",
    "oxlint": "^1.71.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
